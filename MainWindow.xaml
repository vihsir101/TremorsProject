<Window x:Class="CalmHandsWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalmHandsWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#232323">
        <StackPanel Orientation="Vertical">
            <TextBlock Text="{Binding ElementName=XFreqSlider, Path=Value, StringFormat='X-Axis Frequency (Hz): {0:F0}'}" 
            HorizontalAlignment="Center" 
            Margin="0,100,0,10"
            FontWeight="SemiBold"
            FontSize="15"
            Foreground="#69369E"/>

            <Slider x:Name="XFreqSlider"
             Minimum="1" 
             Maximum="12" 
             Value="5" 
             Width="200"
             TickPlacement="BottomRight"
             TickFrequency="1"
             IsSnapToTickEnabled="True"
             Margin="0,0,0,25"
             ValueChanged="Slider_ValueChanged"/>


            <TextBlock Text="{Binding ElementName=YFreqSlider, Path=Value, StringFormat='Y-Axis Frequency (Hz): {0:F0}'}" 
            HorizontalAlignment="Center" 
            Margin="0,0,0,10"
            FontWeight="SemiBold"
            FontSize="15"
            Foreground="#69369E"/>

            <Slider x:Name="YFreqSlider" 
             Minimum="1" 
             Maximum="12" 
             Value="5" 
             Width="200" 
             TickPlacement="BottomRight"
             TickFrequency="1"
             IsSnapToTickEnabled="True"
             Margin="0,0,0,50"
             ValueChanged="Slider_ValueChanged"/>

            <Button x:Name="SaveSettings"
             Width="100"
             Height="30"
             IsEnabled="False"
             Click="SaveSettings_Click"
             Margin="0,0,0,50"
             >Apply Changes</Button>

            <ToggleButton Name="MyToggleButton" 
              Content="ON/OFF" 
              Width="120" 
              Height="40"
              Checked="MyToggleButton_Checked" 
              Unchecked="MyToggleButton_Unchecked"/>

        </StackPanel>
    </Grid>

    
</Window>
